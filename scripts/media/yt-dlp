#!/usr/bin/env bash
set -euo pipefail

##? Usage:
##?   yt-dlp <url> [yt-dlp-options...]
##?   yt-dlp -h | --help
##?
##? Download a video in best mp4 quality.
##? Wrapper around yt-dlp with preferred format options.
##?
##? Examples:
##?   yt-dlp https://youtu.be/VIDEO_ID
##?   yt-dlp https://youtube.com/shorts/VIDEO_ID

if [[ "${1:-}" == "-h" || "${1:-}" == "--help" || $# -eq 0 ]]; then
  grep "^##?" "${BASH_SOURCE[0]}" | cut -c 5-
  exit 0
fi

yt-dlp -f "bv*[ext=mp4]+ba[ext=m4a]/b[ext=mp4]" --merge-output-format mp4 \
  -o "%(title)s.%(ext)s" "$@"
