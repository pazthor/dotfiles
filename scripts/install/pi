#!/usr/bin/env bash
# Installs the pi coding agent CLI + extensions under the current @earendil-works scope.
# Run on a new machine, or to repair a "Cannot find module '@earendil-works/pi-coding-agent'"
# extension-load error caused by the old deprecated @mariozechner/* packages shadowing pi.
# Idempotent.

set -euo pipefail

node_tool="${MISE_NODE_TOOL:-}"
use_mise=0

if command -v mise &>/dev/null; then
    use_mise=1
    if [[ -z "$node_tool" ]]; then
        node_tool="$(mise current node 2>/dev/null | awk 'NR == 1 { print $1 }')"
        node_tool="${node_tool:-node@latest}"
    fi
    if [[ "$node_tool" != node@* ]]; then
        node_tool="node@$node_tool"
    fi
    echo "Installing Node via mise ($node_tool)..."
    mise install "$node_tool"
elif ! command -v npm &>/dev/null; then
    echo "error: npm not found and mise is not installed" >&2
    exit 1
fi

npm_cmd=()
pi_cmd=()

if [[ "$use_mise" -eq 1 ]]; then
    npm_cmd=(mise exec "$node_tool" -- npm)
    pi_cmd=(mise exec "$node_tool" -- pi)
else
    npm_cmd=(npm)
    pi_cmd=(pi)
fi

# The deprecated @mariozechner/pi-coding-agent owns the global `pi` bin symlink;
# its presence makes the new install fail with EEXIST. Remove it first.
if "${npm_cmd[@]}" ls -g --depth=0 2>/dev/null | grep -q "@mariozechner/pi-coding-agent"; then
    echo "Removing deprecated @mariozechner/pi-coding-agent..."
    "${npm_cmd[@]}" uninstall -g @mariozechner/pi-coding-agent
fi

echo "Installing @earendil-works/pi-coding-agent..."
"${npm_cmd[@]}" install -g @earendil-works/pi-coding-agent@latest

echo "Installing/updating pi packages..."
"${npm_cmd[@]}" install -g \
    pi-subagents@latest \
    pi-cursor-sdk@latest \
    @devkade/pi-plan@latest \
    @netandreus/pi-cursor-provider@latest

echo
if command -v pi &>/dev/null; then
    echo "pi -> $(readlink -f "$(command -v pi)")"
else
    echo "pi -> managed by mise ($node_tool)"
fi

if version_output=$("${pi_cmd[@]}" --version 2>&1); then
    version="$(printf '%s\n' "$version_output" | awk '/^[0-9]+[.][0-9]+[.][0-9]+/ { print; exit }')"
    echo "version: ${version:-$version_output}"
else
    echo "error: pi installed but failed to execute:" >&2
    printf '%s\n' "$version_output" >&2
    exit 1
fi

if command -v pi &>/dev/null; then
    if path_version_output="$(pi --version 2>&1)"; then
        path_version="$(printf '%s\n' "$path_version_output" | awk '/^[0-9]+[.][0-9]+[.][0-9]+/ { print; exit }')"
        echo "path version: ${path_version:-$path_version_output}"
    else
        echo "error: pi on PATH failed to execute:" >&2
        printf '%s\n' "$path_version_output" >&2
        exit 1
    fi
fi
echo "Done. Run 'pi list' to confirm extensions are registered."
