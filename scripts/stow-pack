#!/usr/bin/env bash
set -euo pipefail

script_dir=$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)

cat >&2 <<'DEPRECATED'
DEPRECATED: scripts/stow-pack has been replaced by chezmoi-based workflow.

Migration guidance:
  Old: scripts/stow-pack [--restow|--delete] <package>
  New: scripts/chezmoi review
       scripts/chezmoi apply

Any stow arguments passed to this compatibility wrapper are ignored.
DEPRECATED

exec "$script_dir/chezmoi" apply --yes
