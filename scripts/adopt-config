#!/usr/bin/env bash
set -euo pipefail

SCRIPT_NAME=$(basename "$0")

# Canonical package roots for import destinations.
# Format: "<repo_package_root>:<filesystem_root>"
readonly PACKAGE_ROOTS=(
  "config:$HOME"
)

usage() {
  cat >&2 <<USAGE
Usage:
  $SCRIPT_NAME /path/to/home/file
  $SCRIPT_NAME --verify [/path/to/home/file]

Options:
  --verify   Print canonical mapping samples (and optional path mapping) without importing.

Examples:
  $SCRIPT_NAME ~/.config/hypr/bindings.conf
  $SCRIPT_NAME --verify
  $SCRIPT_NAME --verify ~/bin/my-helper
USAGE
}

script_dir=$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)
repo_root=$(cd -- "$script_dir/.." && pwd)

normalize_path() {
  local raw=$1
  raw=${raw/#\~/$HOME}
  readlink -f -- "$raw"
}

resolve_repo_path() {
  local source_path=$1

  if [[ "$source_path" == "$repo_root"/* ]]; then
    echo "Error: input path is already inside this repository: $source_path" >&2
    echo "Action: pass the real file in your home directory instead (for example ~/.config/...)." >&2
    return 1
  fi

  local -a candidates=()
  local entry pkg_root fs_root rel

  for entry in "${PACKAGE_ROOTS[@]}"; do
    pkg_root=${entry%%:*}
    fs_root=${entry#*:}

    if [[ "$source_path" == "$fs_root"/* ]]; then
      rel=${source_path#"$fs_root/"}
      candidates+=("$pkg_root/$rel")
    fi
  done

  if (( ${#candidates[@]} == 0 )); then
    echo "Error: unsupported path: $source_path" >&2
    echo "Action: only files under declared package roots are supported:" >&2
    printf '  - %s\n' "${PACKAGE_ROOTS[@]}" >&2
    return 1
  fi

  if (( ${#candidates[@]} > 1 )); then
    echo "Error: ambiguous mapping for path: $source_path" >&2
    echo "Action: refine PACKAGE_ROOTS so each path matches exactly one mapping." >&2
    printf 'Candidates:\n' >&2
    printf '  - %s\n' "${candidates[@]}" >&2
    return 1
  fi

  printf '%s\n' "${candidates[0]}"
}

print_verify_samples() {
  cat <<'SAMPLES'
Canonical mapping model:
  package root config/ -> $HOME

Sample mappings:
  config/.config/hypr/hyprland.conf -> ~/.config/hypr/hyprland.conf
  config/bin/my-script -> ~/bin/my-script

Scripts handling:
  - scripts/ at repo root contains repository tooling (adopt-config, bootstrap, link-config, etc.).
  - dotfiles intended for ~/bin, ~/.local/bin, etc. belong under config/ (for example config/bin/tool).
SAMPLES
}

verify_mode=0
input_arg=""

case ${1:-} in
  --verify)
    verify_mode=1
    shift
    ;;
  -h|--help)
    usage
    exit 0
    ;;
esac

if [[ $# -gt 1 ]]; then
  usage
  exit 1
fi

if [[ $# -eq 1 ]]; then
  input_arg=$1
fi

if (( verify_mode == 1 )); then
  print_verify_samples
  if [[ -n "$input_arg" ]]; then
    if [[ ! -e "${input_arg/#\~/$HOME}" ]]; then
      echo
      echo "Path check: not found: ${input_arg/#\~/$HOME}" >&2
      exit 1
    fi
    source_path=$(normalize_path "$input_arg")
    repo_relative=$(resolve_repo_path "$source_path")
    echo
    echo "Resolved mapping preview:"
    echo "  Source:      $source_path"
    echo "  Repo path:   $repo_root/$repo_relative"
    echo "  Home target: ${source_path}"
  fi
  exit 0
fi

if [[ -z "$input_arg" ]]; then
  usage
  exit 1
fi

input_path=${input_arg/#\~/$HOME}

if [[ ! -e "$input_path" ]]; then
  echo "Error: file not found: $input_path" >&2
  exit 1
fi

if [[ -L "$input_path" ]]; then
  echo "Error: already a symlink: $input_path" >&2
  exit 1
fi

source_path=$(normalize_path "$input_path")
repo_relative=$(resolve_repo_path "$source_path")
repo_path="$repo_root/$repo_relative"
repo_dir=$(dirname -- "$repo_path")

mkdir -p -- "$repo_dir"

if [[ -e "$repo_path" ]]; then
  echo "Error: target already exists in repo: $repo_path" >&2
  echo "Action: remove/move the existing tracked file, or import a different path." >&2
  exit 1
fi

cp -- "$source_path" "$repo_path"

timestamp=$(date +%Y%m%d%H%M%S)
backup_path="$source_path.bak.$timestamp"

mv -- "$source_path" "$backup_path"
ln -s -- "$repo_path" "$source_path"

git -C "$repo_root" add "$repo_path"

echo "Adopted: $source_path"
echo "Backup:  $backup_path"
echo "Repo:    $repo_path"
