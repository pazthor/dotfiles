#!/usr/bin/env bash
set -euo pipefail

if [[ $# -ne 1 ]]; then
  echo "Usage: $(basename "$0") /path/to/config/file" >&2
  exit 1
fi

input_path=$1
input_path=${input_path/#\~/$HOME}

if [[ ! -e "$input_path" ]]; then
  echo "Error: file not found: $input_path" >&2
  exit 1
fi

if [[ -L "$input_path" ]]; then
  echo "Error: already a symlink: $input_path" >&2
  exit 1
fi

source_path=$(readlink -f -- "$input_path")

if [[ "$source_path" != "$HOME"/* ]]; then
  echo "Error: only paths under $HOME are supported" >&2
  exit 1
fi

script_dir=$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)
repo_root=$(cd -- "$script_dir/.." && pwd)

repo_path="$repo_root/${source_path#"$HOME/"}"
repo_dir=$(dirname -- "$repo_path")

mkdir -p -- "$repo_dir"

if [[ -e "$repo_path" ]]; then
  echo "Error: target already exists in repo: $repo_path" >&2
  exit 1
fi

cp -- "$source_path" "$repo_path"

timestamp=$(date +%Y%m%d%H%M%S)
backup_path="$source_path.bak.$timestamp"

mv -- "$source_path" "$backup_path"
ln -s -- "$repo_path" "$source_path"

git -C "$repo_root" add "$repo_path"

echo "Adopted: $source_path"
echo "Backup:  $backup_path"
echo "Repo:    $repo_path"
