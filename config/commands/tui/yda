#!/bin/bash
set -eu -o pipefail

currentPath=$(pwd)
url=$(wl-paste)
download_dir="$HOME/Downloads/audio"
mkdir -p "$download_dir"
cd "$download_dir" || exit

# Default to mp3; pass --format <fmt> to override (e.g. flac, m4a, opus)
format="mp3"
if [[ "${1:-}" == "--format" ]]; then
  format="$2"
  shift 2
fi

yt-dlp -x --audio-format "$format" --audio-quality 0 "$url" -v -S "ext" "$@"

cd "$currentPath" || exit
