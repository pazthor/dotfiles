#!/usr/bin/env bash
set -euo pipefail

SCRIPT_NAME=$(basename "$0")

# Resolve through the ~/.local/bin symlink so the repo can live anywhere.
self_path=$(readlink -f -- "${BASH_SOURCE[0]}")
repo_root=$(cd -- "$(dirname -- "$self_path")/../../.." && pwd)
scripts_dir="$repo_root/scripts"

list_subcommands() {
  local entry
  for entry in "$scripts_dir"/*; do
    [[ -f "$entry" && -x "$entry" ]] && printf '  %s\n' "$(basename "$entry")"
  done
}

usage() {
  cat >&2 <<USAGE
Usage:
  $SCRIPT_NAME <subcommand> [args...]

Run a dotfiles helper script from anywhere ($scripts_dir).

Subcommands:
$(list_subcommands)

Examples:
  $SCRIPT_NAME adopt-config ~/.config/hypr/bindings.conf
  $SCRIPT_NAME drift
  $SCRIPT_NAME bootstrap
USAGE
}

if [[ $# -eq 0 ]]; then
  usage
  exit 0
fi

case $1 in
  -h|--help) usage; exit 0 ;;
esac

subcommand=$1
shift

target="$scripts_dir/$subcommand"

if [[ ! -f "$target" || ! -x "$target" ]]; then
  echo "Error: unknown subcommand: $subcommand" >&2
  echo "Available subcommands:" >&2
  list_subcommands >&2
  exit 1
fi

exec "$target" "$@"
